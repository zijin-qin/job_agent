# ── Required ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Personal Info ────────────────────────────────────────────────────────────
# These override the placeholder values in data/master_resume.json at runtime.
# They keep your real PII out of any file that might be committed to git.
PERSONAL_NAME=Your Full Name
PERSONAL_EMAIL=your.email@example.com
PERSONAL_PHONE=(555) 000-0000
PERSONAL_LINKEDIN=https://linkedin.com/in/your-profile
PERSONAL_GITHUB=https://github.com/your-username
PERSONAL_LOCATION=City, ST
PERSONAL_CITIZENSHIP=U.S. Citizen

# ── Optional ─────────────────────────────────────────────────────────────────
# Residential proxy for LinkedIn scraping (helps avoid rate limits)
# PROXY_URL=http://user:pass@proxy-host:port

# Set to true to enable Handshake scraping (requires UCSD login on first run)
# USE_HANDSHAKE=true
